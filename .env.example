# Copy to .env.local and fill in values

# Required for AI features (vision, plans, recipes, chat)
GEMINI_API_KEY=  # https://aistudio.google.com/app/apikey

# Optional: nearby CSA / farmers market / food hub lookup
# USDA_LOCALFOOD_API_KEY=  # https://www.usdalocalfoodportal.com/

# Photo ingest: set true to skip Gemini and use data/demo-photo-identified.json
# (useful offline or on bad conference Wi‑Fi).
# DEMO_PHOTO_MOCK=false

# Optional: set to 1 while running npm run dev:https to register the PWA
# service worker on Android/Chrome during local testing.
# NEXT_PUBLIC_PWA_DEV=1
